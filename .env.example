# ============ REQUIRED ============

# Postgres connection string. Free tier: neon.tech (recommended) or supabase.com
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Session + at-rest encryption secret. Generate with: openssl rand -base64 32
# (on Windows PowerShell:  [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 })) )
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# ============ OPTIONAL (all free, app works without them) ============

# AI-written cover letters, outreach emails, and smarter match scoring.
# Without this, built-in keyword scoring and smart templates are used.
# ANTHROPIC_API_KEY="sk-ant-..."

# Radius ("within 25 miles of Chicago") and salary-filtered job search.
# Free key at https://developer.adzuna.com
# ADZUNA_APP_ID=""
# ADZUNA_APP_KEY=""
# ADZUNA_COUNTRY="us"

# Separate key for encrypting stored SMTP passwords (defaults to NEXTAUTH_SECRET)
# APP_ENCRYPTION_KEY=""
